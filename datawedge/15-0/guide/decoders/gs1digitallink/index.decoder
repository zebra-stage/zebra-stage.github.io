    <tr>
      <th style="padding: 8px; text-align: left; background-color: #dce8ef";">1D GTIN-Only</th>
      <th style="padding: 8px; text-align: left; background-color: #dce8ef";">DataBar</th>
      <th style="padding: 8px; text-align: left; background-color: #dce8ef";">2D</th>
    </tr>
  </thead>
  <tbody>
    <tr>
      <td style="padding: 8px;">UPC-A</td>
      <td style="padding: 8px;">GS1 DataBar Omnidirectional</td>
      <td style="padding: 8px;">GS1 Data Matrix</td>
    </tr>
    <tr>
      <td style="padding: 8px;">UPC-E</td>
      <td style="padding: 8px;">GS1 DataBar Expanded</td>
      <td style="padding: 8px;">Data Matrix with GS1 Digital Link URI</td>
    </tr>
    <tr>
      <td style="padding: 8px;">EAN-13</td>
      <td style="padding: 8px;"></td>
